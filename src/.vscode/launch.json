{
    "configurations": [
        {
            "name": "Debug with Makefile",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}\\mesh.exe",
            "args": ["../data/carre_debug.mesh"],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:\\MinGW\\bin\\gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Compile with makefile"
        }
    ],
    "version": "2.0.0"
}